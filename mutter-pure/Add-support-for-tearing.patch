diff --git a/src/backends/native/meta-kms-cursor-manager.c b/src/backends/native/meta-kms-cursor-manager.c
index aa7bc69a56..7e1ebc37c4 100644
--- a/src/backends/native/meta-kms-cursor-manager.c
+++ b/src/backends/native/meta-kms-cursor-manager.c
@@ -442,6 +442,83 @@ maybe_update_cursor_plane (MetaKmsCursorManagerImpl  *cursor_manager_impl,
   return update;
 }
 
+static gboolean
+should_clear_cursor_plane (MetaKmsCursorManagerImpl *cursor_manager_impl,
+                           MetaKmsCrtc              *crtc)
+{
+  CrtcStateImpl *crtc_state_impl;
+  MetaDrmBuffer *buffer;
+  const graphene_point_t *hotspot;
+  float x, y;
+  gboolean should_have_cursor;
+  graphene_rect_t cursor_rect;
+
+  crtc_state_impl = find_crtc_state (cursor_manager_impl, crtc);
+  if (!crtc_state_impl ||
+      !crtc_state_impl->cursor_plane ||
+      !crtc_state_impl->cursor_invalidated ||
+      !crtc_state_impl->has_cursor)
+    {
+      return FALSE;
+    }
+
+  if (!get_current_cursor_position (cursor_manager_impl, &x, &y))
+    return FALSE;
+
+  buffer = crtc_state_impl->buffer;
+  hotspot = &crtc_state_impl->hotspot;
+
+  if (buffer)
+    {
+      should_have_cursor = calculate_cursor_rect (crtc_state_impl,
+                                                  buffer,
+                                                  hotspot,
+                                                  x, y,
+                                                  &cursor_rect);
+    }
+  else
+    {
+      should_have_cursor = FALSE;
+    }
+
+  return !should_have_cursor;
+}
+
+static gboolean
+async_update_needs_cursor_clear (MetaKmsCursorManagerImpl *cursor_manager_impl,
+                                 MetaKmsCrtc              *crtc,
+                                 MetaKmsUpdate            *update,
+                                 MetaKmsUpdateFlag         flags)
+{
+  if (flags & META_KMS_UPDATE_FLAG_TEST_ONLY)
+    return FALSE;
+
+  if (flags & META_KMS_UPDATE_FLAG_MODE_SET)
+    {
+      GPtrArray *crtc_states = cursor_manager_impl->crtc_states;
+      int i;
+
+      g_return_val_if_fail (crtc_states, FALSE);
+
+      for (i = 0; i < crtc_states->len; i++)
+        {
+          CrtcStateImpl *crtc_state_impl = g_ptr_array_index (crtc_states, i);
+          MetaKmsCrtc *state_crtc = crtc_state_impl->crtc;
+
+          if (meta_kms_crtc_get_device (state_crtc) !=
+              meta_kms_update_get_device (update))
+            continue;
+
+          if (should_clear_cursor_plane (cursor_manager_impl, state_crtc))
+            return TRUE;
+        }
+
+      return FALSE;
+    }
+
+  return should_clear_cursor_plane (cursor_manager_impl, crtc);
+}
+
 static void
 free_old_buffers (gpointer      retval,
                   const GError *error,
@@ -474,7 +551,13 @@ update_filter_cb (MetaKmsImpl       *impl,
    * Reference: KWin drm_output.cpp shouldDisableNonPrimaryPlanes() */
   if (update && meta_kms_update_get_async (update))
     {
-      return update;
+      /* Allow one synchronous transition commit to clear a stale hardware
+       * cursor plane. Otherwise keep skipping cursor plane updates in async
+       * mode to avoid kernel rejections and ghost cursors. */
+      if (!async_update_needs_cursor_clear (cursor_manager_impl, crtc, update, flags))
+        return update;
+
+      meta_kms_update_set_async (update, FALSE);
     }
 
   if (flags & META_KMS_UPDATE_FLAG_TEST_ONLY)
