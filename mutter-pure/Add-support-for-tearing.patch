 #define META_TYPE_WAYLAND_TEARING_SURFACE (meta_wayland_tearing_surface_get_type ())
@@ -96,6 +95,17 @@ static const struct wp_tearing_control_v1_interface tearing_surface_interface =
   wp_tearing_control_destroy,
 };
 
+static void
+on_surface_weak_notify (gpointer  data,
+                        GObject  *where_the_object_was)
+{
+  MetaWaylandTearingSurface *tearing_surface = data;
+  
+  /* Surface has been destroyed - just clear our pointer.
+   * Called AFTER destruction, so we can't access the surface. */
+  tearing_surface->surface = NULL;
+}
+
