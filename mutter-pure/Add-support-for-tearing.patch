Signed-off-by: Vasiliy Stelmachenok <ventureo@cachyos.org>
---
 src/compositor/meta-compositor-view-native.c | 5 +----
 1 file changed, 1 insertion(+), 4 deletions(-)

diff --git a/src/compositor/meta-compositor-view-native.c b/src/compositor/meta-compositor-view-native.c
index a4ac5de50d..1fe98739c3 100644
--- a/src/compositor/meta-compositor-view-native.c
+++ b/src/compositor/meta-compositor-view-native.c
@@ -492,14 +492,11 @@ update_fullscreen_actor (MetaCompositorViewNative *view_native,
       if (window && meta_window_is_fullscreen (window))
         {
           MetaCrtc *view_crtc = meta_onscreen_native_get_crtc (onscreen_native);
-          MetaCrtc *scanout_candidate =
-            meta_wayland_surface_get_scanout_candidate (surface);
           MetaBackend *backend = meta_crtc_get_backend (view_crtc);
           MetaSettings *settings = meta_backend_get_settings (backend);
 
           if (meta_settings_is_experimental_feature_enabled (
-                settings, META_EXPERIMENTAL_FEATURE_AUTO_FULLSCREEN_TEARING) &&
-              scanout_candidate == view_crtc)
+                settings, META_EXPERIMENTAL_FEATURE_AUTO_FULLSCREEN_TEARING))
             tearing_enabled = TRUE;
         }
     }
