From 831f626405affe088ea9f0658325851cbee9e198 Mon Sep 17 00:00:00 2001
From: Vasiliy Stelmachenok <ventureo@cachyos.org>
Date: Thu, 9 Apr 2026 18:47:39 +0300
Subject: [PATCH 17/17] Fix crash if pending surface state is NULL

Signed-off-by: Vasiliy Stelmachenok <ventureo@cachyos.org>
---
 src/wayland/meta-wayland-tearing-control.c | 10 +++++++---
 1 file changed, 7 insertions(+), 3 deletions(-)

diff --git a/src/wayland/meta-wayland-tearing-control.c b/src/wayland/meta-wayland-tearing-control.c
index 9f63ef0fac..d979d3e084 100644
--- a/src/wayland/meta-wayland-tearing-control.c
+++ b/src/wayland/meta-wayland-tearing-control.c
@@ -100,7 +100,7 @@ on_surface_weak_notify (gpointer  data,
                         GObject  *where_the_object_was)
 {
   MetaWaylandTearingSurface *tearing_surface = data;
-  
+
   /* Surface has been destroyed - just clear our pointer.
    * Called AFTER destruction, so we can't access the surface. */
   tearing_surface->surface = NULL;
@@ -132,8 +132,12 @@ clear_tearing_surface_data (MetaWaylandTearingSurface *tearing_surface)
                        tearing_surface);
 
   pending = meta_wayland_surface_get_pending_state (surface);
-  pending->allow_tearing = FALSE;
-  pending->has_new_allow_tearing = TRUE;
+
+  if (pending) {
+    pending->allow_tearing = FALSE;
+    pending->has_new_allow_tearing = TRUE;
+  }
+
   tearing_surface->surface = NULL;
 }
 
-- 
