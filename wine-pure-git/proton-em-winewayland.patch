From 2a6bae447a754ce0d83a6e7e807d40c05f41d81d Mon Sep 17 00:00:00 2001
From: Etaash Mathamsetty
 <45927311+Etaash-mathamsetty@users.noreply.github.com>
Date: Tue, 21 Apr 2026 23:10:08 -0500
Subject: [PATCH 31/83] winewayland: Implement edid emulation.

Signed-off-by: Vasiliy Stelmachenok <ventureo@cachyos.org>
---
 dlls/winewayland.drv/display.c | 61 ++++++++++++++++++++++++++++++++++
 1 file changed, 61 insertions(+)

diff --git a/dlls/winewayland.drv/display.c b/dlls/winewayland.drv/display.c
index 4086190e0fe..5c1c27fd3b7 100644
--- a/dlls/winewayland.drv/display.c
+++ b/dlls/winewayland.drv/display.c
@@ -204,6 +204,65 @@ static void wayland_add_device_source(const struct gdi_device_manager *device_ma
     device_manager->add_source(output_info->output->name, state_flags, dpi, param);
 }
 
+static UINT get_edid(struct output_info *output_info, unsigned char **edid)
+{
+    struct wayland_output_mode *mode = output_info->output->current_mode;
+    unsigned int edid_size = 128, extensions = 0;
+    unsigned int i, mwidth, mheight;
+    unsigned char *data, *p, c;
+
+    if (!(*edid = calloc(edid_size, sizeof(**edid))))
+        return 0;
+
+    data = *edid;
+
+    /* assume ~150 dpi */
+    mwidth = mode->width / 60;
+    mheight = mode->width / 60;
+
+    *(uint64_t*)data = 0x00ffffffffffff00;
+    data[16] = 0xFF;
+    data[17] = 31; /* 2021 */
+    data[18] = 1;
+    data[19] = 4;
+    data[20] = 0xa0; /* FIXME */
+    data[21] = round(mwidth / 10.0); /* cm */
+    data[22] = round(mheight / 10.0); /* cm */
+    data[24] = 0x6;
+
+    for (i = 0; i < 16; ++i) data[38 + i] = 1;
+
+    p = data + 54;
+
+    *(uint16_t*)p = 0x0; /* 0 = reserved */
+
+    /* assume blanking time is 0 */
+    p[2] = mode->width;
+    p[4] = (((mode->width >> 8) & 0xf) << 4);
+    p[5] = mode->height;
+    p[7] = (((mode->height >> 8) & 0xf) << 4);
+    p[12] = mwidth;
+    p[13] = mheight;
+    p[14] = (((mwidth >> 8) & 0xf) << 4) | ((mheight >> 8) & 0xf);
+
+    p += 18;
+    p[3] = 0xfc;
+    strcpy( (char *)p + 5, "Default" );
+
+    p += 18;
+    p[3] = 0x10;
+    p += 18;
+    p[3] = 0x10;
+
+    c = 0;
+    data[126] = extensions;
+    for (i = 0; i < 127; ++i)
+        c += data[i];
+    data[127] = 256 - c;
+
+    return edid_size;
+}
+
 static void wayland_add_device_monitor(const struct gdi_device_manager *device_manager,
                                        void *param, struct output_info *output_info)
 {
@@ -213,6 +272,7 @@ static void wayland_add_device_monitor(const struct gdi_device_manager *device_m
             output_info->x + output_info->output->current_mode->width,
             output_info->y + output_info->output->current_mode->height);
 
+    monitor.edid_len = get_edid(output_info, &monitor.edid);
     /* We don't have a direct way to get the work area in Wayland. */
     monitor.rc_work = monitor.rc_monitor;
 
@@ -220,6 +280,7 @@ static void wayland_add_device_monitor(const struct gdi_device_manager *device_m
           output_info->output->name, wine_dbgstr_rect(&monitor.rc_monitor));
 
     device_manager->add_monitor(&monitor, param);
+    free(monitor.edid);
 }
 
 static void populate_devmode(struct wayland_output_mode *output_mode, DEVMODEW *mode)
