From e12b0f711497b6a67574bca73191dc45a89d161c Mon Sep 17 00:00:00 2001
From: Sultech <6282-Sultech@users.noreply.gitlab.gnome.org>
Date: Tue, 10 Feb 2026 22:58:31 +0000
Subject: [PATCH 16/17] tearing: Keep async+VRR coexistence and refresh
 fullscreen policy

Signed-off-by: Vasiliy Stelmachenok <ventureo@cachyos.org>
---
 src/backends/native/meta-onscreen-native.c   | 30 +++++++++++-
 src/compositor/meta-compositor-view-native.c | 50 ++++++++++----------
 2 files changed, 53 insertions(+), 27 deletions(-)

diff --git a/src/backends/native/meta-onscreen-native.c b/src/backends/native/meta-onscreen-native.c
index 8a29b08a0b..621278b08b 100644
--- a/src/backends/native/meta-onscreen-native.c
+++ b/src/backends/native/meta-onscreen-native.c
@@ -181,6 +181,9 @@ post_nonprimary_plane_update (MetaOnscreenNative *onscreen_native,
                               ClutterFrame       *frame,
                               MetaKmsUpdate      *kms_update);
 
+static gboolean
+should_use_async_page_flip (MetaOnscreenNative *onscreen_native);
+
 static gboolean
 init_secondary_gpu_state (MetaRendererNative  *renderer_native,
                           CoglOnscreen        *onscreen,
@@ -2115,7 +2118,7 @@ maybe_post_next_frame (CoglOnscreen *onscreen)
     }
 
   meta_kms_update_set_async (kms_update,
-                             onscreen_native->tearing_enabled);
+                             should_use_async_page_flip (onscreen_native));
 
   meta_kms_device_post_update (kms_device, kms_update,
                                META_KMS_UPDATE_FLAG_NONE);
@@ -2128,6 +2131,29 @@ post_failed:
   meta_onscreen_native_notify_frame_complete (onscreen);
 }
 
+static gboolean
+should_use_async_page_flip (MetaOnscreenNative *onscreen_native)
+{
+  MetaCrtcKms *crtc_kms;
+  MetaKmsCrtc *kms_crtc;
+  const MetaKmsCrtcState *crtc_state;
+
+  if (!onscreen_native->tearing_enabled)
+    return FALSE;
+
+  crtc_kms = META_CRTC_KMS (onscreen_native->crtc);
+  kms_crtc = meta_crtc_kms_get_kms_crtc (crtc_kms);
+  crtc_state = meta_kms_crtc_get_current_state (kms_crtc);
+
+  /* Async commits are restricted to primary FB updates; if VRR needs to be
+   * toggled this frame, force a synchronous transition commit. */
+  if (crtc_state->vrr.supported &&
+      onscreen_native->vrr_enabled != crtc_state->vrr.enabled)
+    return FALSE;
+
+  return TRUE;
+}
+
 gboolean
 meta_onscreen_native_is_buffer_scanout_compatible (CoglOnscreen *onscreen,
                                                    CoglScanout  *scanout)
@@ -2155,7 +2181,7 @@ meta_onscreen_native_is_buffer_scanout_compatible (CoglOnscreen *onscreen,
   cogl_scanout_get_dst_rect (scanout, &dst_rect);
 
   meta_kms_update_set_async (test_update,
-                             onscreen_native->tearing_enabled);
+                             should_use_async_page_flip (onscreen_native));
 
   buffer = META_DRM_BUFFER (cogl_scanout_get_buffer (scanout));
   assign_primary_plane (crtc_kms,
diff --git a/src/compositor/meta-compositor-view-native.c b/src/compositor/meta-compositor-view-native.c
index 1fe98739c3..13f6947a93 100644
--- a/src/compositor/meta-compositor-view-native.c
+++ b/src/compositor/meta-compositor-view-native.c
@@ -429,30 +429,33 @@ update_fullscreen_actor (MetaCompositorViewNative *view_native,
   MetaWaylandSurface *surface;
   gboolean tearing_enabled;
 
-  g_clear_signal_handler (&view_native->fullscreen_surface_repaint_scheduled_id,
-                          view_native->fullscreen_actor);
-  g_clear_signal_handler (&view_native->fullscreen_surface_update_scheduled_id,
-                          view_native->fullscreen_actor);
-  g_clear_signal_handler (&view_native->fullscreen_actor_destroy_id,
-                          view_native->fullscreen_actor);
-
-  if (surface_actor)
+  if (surface_actor != view_native->fullscreen_actor)
     {
-      view_native->fullscreen_surface_repaint_scheduled_id =
-        g_signal_connect (surface_actor, "repaint-scheduled",
-                          G_CALLBACK (maybe_set_fullscreen_update_time),
-                          view_native);
-      view_native->fullscreen_surface_update_scheduled_id =
-        g_signal_connect (surface_actor, "update-scheduled",
-                          G_CALLBACK (maybe_set_fullscreen_update_time),
-                          view_native);
-      view_native->fullscreen_actor_destroy_id =
-        g_signal_connect (surface_actor, "destroy",
-                          G_CALLBACK (on_fullscreen_actor_destroyed),
-                          view_native);
-    }
+      g_clear_signal_handler (&view_native->fullscreen_surface_repaint_scheduled_id,
+                              view_native->fullscreen_actor);
+      g_clear_signal_handler (&view_native->fullscreen_surface_update_scheduled_id,
+                              view_native->fullscreen_actor);
+      g_clear_signal_handler (&view_native->fullscreen_actor_destroy_id,
+                              view_native->fullscreen_actor);
+
+      if (surface_actor)
+        {
+          view_native->fullscreen_surface_repaint_scheduled_id =
+            g_signal_connect (surface_actor, "repaint-scheduled",
+                              G_CALLBACK (maybe_set_fullscreen_update_time),
+                              view_native);
+          view_native->fullscreen_surface_update_scheduled_id =
+            g_signal_connect (surface_actor, "update-scheduled",
+                              G_CALLBACK (maybe_set_fullscreen_update_time),
+                              view_native);
+          view_native->fullscreen_actor_destroy_id =
+            g_signal_connect (surface_actor, "destroy",
+                              G_CALLBACK (on_fullscreen_actor_destroyed),
+                              view_native);
+        }
 
-  view_native->fullscreen_actor = surface_actor;
+      view_native->fullscreen_actor = surface_actor;
+    }
 
   stage_view = meta_compositor_view_get_stage_view (compositor_view);
 
@@ -515,9 +518,6 @@ meta_compositor_view_native_maybe_update_fullscreen_actor (MetaCompositorViewNat
 
   fullscreen_actor = find_fullscreen_candidate (compositor_view, compositor);
 
-  if (G_LIKELY (fullscreen_actor == view_native->fullscreen_actor))
-    return;
-
   update_fullscreen_actor (view_native, fullscreen_actor);
 }
 
-- 
