 {
@@ -144,8 +149,13 @@ meta_wayland_tearing_surface_dispose (GObject *object)
 {
   MetaWaylandTearingSurface *tearing_surface = META_WAYLAND_TEARING_SURFACE (object);
 
-  g_clear_signal_handler (&tearing_surface->destroy_handler_id,
-                          tearing_surface->surface);
+  /* Clean up weak reference if surface still exists */
+  if (tearing_surface->surface)
+    {
+      g_object_weak_unref (G_OBJECT (tearing_surface->surface),
+                           on_surface_weak_notify,
+                           tearing_surface);
+    }
 
   G_OBJECT_CLASS (meta_wayland_tearing_surface_parent_class)->dispose (object);
 }
@@ -171,10 +181,11 @@ meta_wayland_tearing_surface_new (MetaWaylandSurface *surface)
   tearing_surface = g_object_new (META_TYPE_WAYLAND_TEARING_SURFACE, NULL);
   tearing_surface->surface = surface;
 
-  tearing_surface->destroy_handler_id =
-    g_signal_connect (tearing_surface->surface, "destroy",
-                      G_CALLBACK (on_surface_destroyed),
-                      tearing_surface);
+  /* Use weak reference instead of signal handler.
+   * Called AFTER surface destruction, not during. */
+  g_object_weak_ref (G_OBJECT (tearing_surface->surface),
+                     on_surface_weak_notify,
+                     tearing_surface);
   return tearing_surface;
 }
 
@@ -212,11 +223,6 @@ wp_tearing_control_manager_get_tearing_control (struct wl_client   *client,
                                   g_object_ref (tearing_surface),
                                   tearing_control_surface_destructor);
 
-  tearing_surface->destroy_handler_id =
-    g_signal_connect (tearing_surface->surface, "destroy",
